{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ANWE",
  "scopeName": "source.anwe",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#agent-declaration" },
    { "include": "#mind-declaration" },
    { "include": "#link-declaration" },
    { "include": "#pattern-declaration" },
    { "include": "#supervisor-declaration" },
    { "include": "#record-declaration" },
    { "include": "#function-declaration" },
    { "include": "#import-statement" },
    { "include": "#keywords" },
    { "include": "#cognitive-keywords" },
    { "include": "#signal-keywords" },
    { "include": "#temporal-keywords" },
    { "include": "#error-handling" },
    { "include": "#signal-qualities" },
    { "include": "#agent-states" },
    { "include": "#directionality" },
    { "include": "#constants" },
    { "include": "#link-operators" },
    { "include": "#operators" },
    { "include": "#lambda" },
    { "include": "#punctuation" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.anwe",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.interpolated.anwe",
          "begin": "f\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "string.interpolated.begin.anwe" }
          },
          "endCaptures": {
            "0": { "name": "string.interpolated.end.anwe" }
          },
          "patterns": [
            {
              "name": "meta.interpolation.anwe",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.anwe" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.anwe" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            },
            {
              "name": "constant.character.escape.anwe",
              "match": "\\\\[\\\\\"nrt{}]"
            }
          ]
        },
        {
          "name": "string.quoted.double.anwe",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.anwe",
              "match": "\\\\[\\\\\"nrt]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.anwe",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.anwe",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "agent-declaration": {
      "patterns": [
        {
          "match": "\\b(agent)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.agent.anwe" },
            "2": { "name": "entity.name.type.agent.anwe" }
          }
        }
      ]
    },
    "mind-declaration": {
      "patterns": [
        {
          "match": "\\b(mind)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.mind.anwe" },
            "2": { "name": "entity.name.type.mind.anwe" }
          }
        }
      ]
    },
    "link-declaration": {
      "patterns": [
        {
          "match": "\\b(link)\\s+([A-Z][a-zA-Z0-9_.]*)",
          "captures": {
            "1": { "name": "keyword.declaration.link.anwe" },
            "2": { "name": "entity.name.type.anwe" }
          }
        }
      ]
    },
    "pattern-declaration": {
      "patterns": [
        {
          "match": "\\b(pattern)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.pattern.anwe" },
            "2": { "name": "entity.name.type.pattern.anwe" }
          }
        }
      ]
    },
    "supervisor-declaration": {
      "patterns": [
        {
          "match": "\\b(supervise|supervisor)\\s+(one_for_one|rest_for_one|one_for_all)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.supervisor.anwe" },
            "2": { "name": "support.constant.strategy.anwe" }
          }
        }
      ]
    },
    "record-declaration": {
      "patterns": [
        {
          "match": "\\b(record)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.record.anwe" },
            "2": { "name": "entity.name.type.record.anwe" }
          }
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.declaration.function.anwe" },
            "2": { "name": "entity.name.function.anwe" }
          }
        }
      ]
    },
    "import-statement": {
      "patterns": [
        {
          "match": "\\b(import)\\b",
          "name": "keyword.control.import.anwe"
        },
        {
          "match": "\\b(from)\\b",
          "name": "keyword.control.from.anwe"
        },
        {
          "match": "\\b(as)\\b",
          "name": "keyword.control.as.anwe"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.anwe",
          "match": "\\b(agent|link|mind|pattern|supervisor|record)\\b"
        },
        {
          "name": "keyword.control.anwe",
          "match": "\\b(if|else|match|while|for|in|break|continue|return)\\b"
        },
        {
          "name": "storage.type.anwe",
          "match": "\\b(let\\s+mut|let)\\b"
        },
        {
          "name": "keyword.declaration.function.anwe",
          "match": "\\b(fn)\\b"
        },
        {
          "name": "keyword.other.supervision.anwe",
          "match": "\\b(supervise|max_restarts|within|permanent|transient|temporary)\\b"
        },
        {
          "name": "keyword.other.supervision.strategy.anwe",
          "match": "\\b(one_for_one|rest_for_one|one_for_all)\\b"
        },
        {
          "name": "keyword.other.modifier.anwe",
          "match": "\\b(priority|attention|data|budget|decay|schedule|depth|timeout|on_failure_of|external)\\b"
        },
        {
          "name": "support.constant.priority-level.anwe",
          "match": "\\b(high|normal|low|critical)(?=\\s|\\{|$)"
        },
        {
          "name": "support.constant.depth-level.anwe",
          "match": "\\b(surface|partial|deep|full|genuine)(?=\\s|\\{|$)"
        },
        {
          "name": "keyword.other.sync.anwe",
          "match": "\\b(until|synchronized)\\b"
        },
        {
          "name": "keyword.other.history.anwe",
          "match": "\\b(history_of)\\b"
        }
      ]
    },
    "cognitive-keywords": {
      "patterns": [
        {
          "name": "keyword.cognitive.anwe",
          "match": "\\b(think|sense|express|author|attend)\\b"
        },
        {
          "name": "keyword.cognitive.action.anwe",
          "match": "\\b(alert|connect|sync|apply|commit|reject|converge)\\b"
        }
      ]
    },
    "signal-keywords": {
      "patterns": [
        {
          "name": "keyword.signal.anwe",
          "match": "\\b(signal|emit)\\b"
        }
      ]
    },
    "temporal-keywords": {
      "patterns": [
        {
          "name": "keyword.temporal.anwe",
          "match": "\\b(when|on|every|after|continuous|ticks)\\b"
        }
      ]
    },
    "error-handling": {
      "patterns": [
        {
          "name": "keyword.control.trycatch.anwe",
          "match": "\\b(try|catch|attempt|recover)\\b"
        }
      ]
    },
    "signal-qualities": {
      "patterns": [
        {
          "name": "support.type.signal-quality.anwe",
          "match": "\\b(recognizing|questioning|applying|completing|connecting|alerting|attending|resting)\\b"
        }
      ]
    },
    "agent-states": {
      "patterns": [
        {
          "name": "support.type.agent-state.anwe",
          "match": "\\b(idle|alert|connected|synced|committed|rejected|converged)\\b"
        }
      ]
    },
    "directionality": {
      "patterns": [
        {
          "name": "support.constant.direction.anwe",
          "match": "\\b(inward|outward|between)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.anwe",
          "match": "\\b(true)\\b"
        },
        {
          "name": "constant.language.boolean.false.anwe",
          "match": "\\b(false)\\b"
        },
        {
          "name": "constant.language.null.anwe",
          "match": "\\b(null)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.convergence.anwe",
          "match": "<<>>"
        },
        {
          "name": "keyword.operator.comparison.anwe",
          "match": "==|!=|>=|<=(?!=)"
        },
        {
          "name": "keyword.operator.fat-arrow.anwe",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipe.anwe",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.logical.anwe",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.anwe",
          "match": "<-(?!>)"
        },
        {
          "name": "keyword.operator.arrow.anwe",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.anwe",
          "match": ">|<"
        },
        {
          "name": "keyword.operator.arithmetic.anwe",
          "match": "\\+|-(?!-)(?!>)|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.equals.anwe",
          "match": "=(?!=|>)"
        }
      ]
    },
    "link-operators": {
      "patterns": [
        {
          "name": "keyword.operator.link.bidirectional.anwe",
          "match": "<->"
        },
        {
          "name": "keyword.operator.link.sync.anwe",
          "match": "~"
        },
        {
          "name": "keyword.operator.signal-marker.anwe",
          "match": ">>|\\*(?=\\s+from)"
        }
      ]
    },
    "lambda": {
      "patterns": [
        {
          "match": "\\|([^|]*)\\|",
          "captures": {
            "0": { "name": "meta.lambda.parameters.anwe" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.anwe" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.definition.block.anwe",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.brackets.anwe",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.parameters.anwe",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.anwe",
          "match": ","
        },
        {
          "name": "punctuation.separator.key-value.anwe",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.property.anwe",
          "match": "(?<=\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        },
        {
          "name": "entity.name.type.anwe",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        },
        {
          "name": "variable.other.anwe",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    }
  }
}
